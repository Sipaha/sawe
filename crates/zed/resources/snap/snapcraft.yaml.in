name: sawe
title: Sawe
base: core24
version: "$RELEASE_VERSION"
summary: Personal fork of Zed code editor
description: |
  Sawe is a personal fork of Zed by Zed Industries, Inc., modified by
  Simonov Pavel. It is a modern open-source code editor, built from the ground
  up in Rust with a GPU-accelerated renderer.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/Sipaha/sawe
source-code: https://github.com/Sipaha/sawe
issues: https://github.com/Sipaha/sawe/issues
contact: https://github.com/Sipaha/sawe/issues

parts:
  sawe:
    plugin: dump
    source: "https://github.com/Sipaha/sawe/releases/download/v$RELEASE_VERSION/sawe-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Sawe exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Sawe exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  sawe:
    command: usr/bin/sawe
    common-id: ru.sipaha.sawe
    environment:
      ZED_BUNDLE_TYPE: snap
